{
  "extends": "../tsconfig.base.json",
  "compilerOptions": {
    "lib": ["DOM", "DOM.Iterable", "ES2022"],
    "types": ["node", "vite/client"],
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",

    "jsx": "react-jsx",
    "rootDirs": [".", "./.react-router/**"],

    "paths": {
      "@/*": ["./src/*"]
    },

    "incremental": true,
    "esModuleInterop": true,
    "noEmit": true,
    "verbatimModuleSyntax": true,
    "resolveJsonModule": true,
    "skipLibCheck": true,
    "strict": true
  },
  "include": [
    "src/**/*",
    ".react-router/types/**/*",
    "*.config.ts"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "build",
    "coverage",
    "logs",
    ".next",
    ".turbo"
  ]
}
